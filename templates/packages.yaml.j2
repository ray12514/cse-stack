packages:
  all:
    target: [{{ cpu_arch }}]
    providers:
{% if is_openmpi %}
      mpi: [openmpi]
{% else %}
      mpi: [mpich]
{% endif %}
    require:
      - "%gcc@{{ gcc_version }}"
    permissions:
      read:  world
      write: group
      group: {{ cse_group }}

  # OS-level externals (both variants)
  openssl:
    buildable: false
    externals:
      - spec: openssl@3.0.7
        prefix: /usr
  curl:
    buildable: true
    externals:
      - spec: curl@7.85.0
        prefix: /usr
  glibc:
    buildable: false
    externals:
      - spec: glibc@{{ glibc_version }}
        prefix: /usr
  perl:
    buildable: true
    externals:
      - spec: perl@5.32.1
        prefix: /usr

  # Python is registered as an external hint but left buildable so a downstream
  # spec that requires a newer Python can trigger a rebuild rather than hard-failing.
  python:
    externals:
      - spec: python@3.11.5
        prefix: /usr

  # Bootstrapped GCC — registered as external after stage2_spack.sh builds it.
  # Both variants bootstrap GCC from Spack (no vendor compiler dependency).
  gcc:
    buildable: false
    externals:
      - spec: gcc@{{ gcc_version }} languages='c,c++,fortran'
        prefix: {{ bootstrap_prefix }}
        extra_attributes:
          compilers:
            c:       {{ bootstrap_prefix }}/bin/gcc
            cxx:     {{ bootstrap_prefix }}/bin/g++
            fortran: {{ bootstrap_prefix }}/bin/gfortran
          extra_rpaths:
            - {{ bootstrap_prefix }}/lib64

{% if is_mpich and has_libfabric %}
  # libfabric — system OFI provider (Cray Slingshot HSN).
  # Detected from modules.loaded by Cluster Inspector; enables MPICH to use
  # the native high-speed network without building libfabric from source.
  libfabric:
    buildable: false
    externals:
      - spec: libfabric@{{ libfabric_version }}
        prefix: {{ libfabric_prefix }}
        modules: [libfabric/{{ libfabric_version }}]
{% endif %}

{% if is_mpich and has_cray_pals %}
  # cray-pals — PBS job launcher / PMIx provider on Cray systems.
  # Provides mpiexec that hooks into Slingshot for PBS compute node launch.
  # Absent on Slurm Cray systems; detected automatically by Stage 1.
  pals:
    buildable: false
    externals:
      - spec: pals@{{ cray_pals_version }}
        modules: [cray-pals/{{ cray_pals_version }}]
        prefix: {{ cray_pals_prefix }}
{% endif %}
