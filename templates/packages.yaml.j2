packages:
  all:
    target: [{{ cpu_arch }}]
    providers:
{% if is_variant_a %}
      mpi: [openmpi]
{% else %}
      mpi:    [cray-mpich]
      blas:   [cray-libsci]
      lapack: [cray-libsci]
      scalapack: [cray-libsci]
{% endif %}
    require:
{% if is_variant_a %}
      - "%gcc@{{ gcc_version }}"
{% else %}
      - "%gcc@{{ prgenv_gcc_version }}"
{% endif %}
    permissions:
      read:  world
      write: group
      group: {{ cse_group }}

  # OS-level externals (both variants)
  openssl:
    buildable: false
    externals:
      - spec: openssl@3.0.7
        prefix: /usr
  curl:
    buildable: true
    externals:
      - spec: curl@7.85.0
        prefix: /usr
  glibc:
    buildable: false
    externals:
      - spec: glibc@{{ glibc_version }}
        prefix: /usr
  perl:
    buildable: true
    externals:
      - spec: perl@5.32.1
        prefix: /usr

  # Python is registered as an external hint but left buildable so a downstream
  # spec that requires a newer Python can trigger a rebuild rather than hard-failing.
  python:
    externals:
      - spec: python@3.11.5
        prefix: /usr

{% if is_variant_a %}
  # Bootstrapped GCC — registered as external after stage2_spack.sh builds it.
  gcc:
    buildable: false
    externals:
      - spec: gcc@{{ gcc_version }} languages='c,c++,fortran'
        prefix: {{ bootstrap_prefix }}
        extra_attributes:
          compilers:
            c:       {{ bootstrap_prefix }}/bin/gcc
            cxx:     {{ bootstrap_prefix }}/bin/g++
            fortran: {{ bootstrap_prefix }}/bin/gfortran
          extra_rpaths:
            - {{ bootstrap_prefix }}/lib64
{% else %}
  # Cray substrate externals — versions read from Stage 1 (Cluster Inspector).
  gcc:
    buildable: false
    externals:
      - spec: gcc@{{ prgenv_gcc_version }} languages='c,c++,fortran'
        prefix: {{ prgenv_gcc_prefix }}
        modules:
          - PrgEnv-gnu
          - gcc/{{ prgenv_gcc_version }}
        extra_attributes:
          compilers:
            c:       {{ prgenv_gcc_prefix }}/bin/gcc
            cxx:     {{ prgenv_gcc_prefix }}/bin/g++
            fortran: {{ prgenv_gcc_prefix }}/bin/gfortran

  cray-mpich:
    buildable: false
    externals:
      - spec: cray-mpich@{{ cray_mpich_version }} %gcc@{{ prgenv_gcc_version }}
        modules: [cray-mpich/{{ cray_mpich_version }}]
        prefix: {{ cray_mpich_prefix }}

  cray-libsci:
    buildable: false
    externals:
      - spec: cray-libsci@{{ cray_libsci_version }}
        modules: [cray-libsci/{{ cray_libsci_version }}]
        prefix: {{ cray_libsci_prefix }}

{% if has_cray_pals %}
  # cray-pals provides mpiexec on PBS Cray systems; absent on Slurm Cray.
  # Presence is detected automatically by Stage 1 (Cluster Inspector).
  cray-pals:
    buildable: false
    externals:
      - spec: cray-pals@{{ cray_pals_version }}
        modules: [cray-pals/{{ cray_pals_version }}]
        prefix: {{ cray_pals_prefix }}
{% endif %}
{% endif %}
