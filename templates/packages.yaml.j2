packages:
  all:
    target: [{{ cpu_arch }}]
    providers:
      mpi: [{{ mpi_provider }}]
    permissions:
      read:  world
      write: group
      group: {{ cse_group }}

{% if openssl_mode == "external" %}
  # OS-level OpenSSL is always site-managed. Deploy preflight validates that
  # the detected version satisfies the selected package set before concretize.
  openssl:
    buildable: false
{% if openssl_version %}
    externals:
      - spec: openssl@{{ openssl_version }}
        prefix: {{ openssl_prefix }}
{% endif %}
{% endif %}
  curl:
    buildable: true
{% if curl_version %}
    externals:
      - spec: curl@{{ curl_version }}
        prefix: {{ curl_prefix }}
{% endif %}
  glibc:
    buildable: false
    externals:
      - spec: glibc@{{ glibc_version }}
        prefix: /usr
  perl:
    buildable: true
{% if perl_version %}
    externals:
      - spec: perl@{{ perl_version }}
        prefix: {{ perl_prefix }}
{% endif %}
  python:
    buildable: true
{% if python_version %}
    externals:
      - spec: python@{{ python_version }}
        prefix: {{ python_prefix }}
{% endif %}
{% if is_mpich and has_libfabric %}
  # libfabric — system OFI provider (Cray Slingshot HSN).
  # Detected from modules.loaded by Cluster Inspector; enables MPICH to use
  # the native high-speed network without building libfabric from source.
  libfabric:
    buildable: false
    externals:
      - spec: libfabric{% if libfabric_version %}@{{ libfabric_version }}{% endif %}
        prefix: {{ libfabric_prefix }}
{% if libfabric_module %}
        modules: [{{ libfabric_module }}]
{% endif %}
{% endif %}

{% if is_mpich and scheduler_type == "slurm" and has_slurm %}
  # slurm — site scheduler/runtime for srun-based MPI launch.
  slurm:
    buildable: false
    externals:
      - spec: slurm{% if slurm_version %}@{{ slurm_version }}{% endif %}
        prefix: {{ slurm_prefix }}
{% if slurm_module %}
        modules: [{{ slurm_module }}]
{% endif %}
{% endif %}

{% if is_mpich and scheduler_type == "slurm" and has_pmix %}
  # pmix — site PMIx used by MPICH pmi=pmix with Slurm launch.
  pmix:
    buildable: false
    externals:
      - spec: pmix{% if pmix_version %}@{{ pmix_version }}{% endif %}
        prefix: {{ pmix_prefix }}
{% if pmix_module %}
        modules: [{{ pmix_module }}]
{% endif %}
{% endif %}

{% if is_cce and cce_version %}
  # CCE — detected from CRAY_CC_VERSION / CRAY_PE_CCE_FIXUP_PREFIX set by PrgEnv-cray.
  cce:
    buildable: false
    externals:
      - spec: cce@{{ cce_version }} languages='c,c++,fortran'
        prefix: {{ cce_prefix }}
{% endif %}

{% if is_craympich and cray_mpich_version %}
  # cray-mpich — always external; performance depends on Cray Slingshot HSN.
  cray-mpich:
    buildable: false
    externals:
      - spec: cray-mpich@{{ cray_mpich_version }}
        prefix: {{ cray_mpich_prefix }}
{% if cray_mpich_module %}
        modules: [{{ cray_mpich_module }}]
{% endif %}
{% endif %}

{% if is_aocc and aocc_version %}
  # AOCC — detected from AOCC_VERSION / AOCC_HOME set by PrgEnv-aocc or module load aocc.
  aocc:
    buildable: false
    externals:
      - spec: aocc@{{ aocc_version }} languages='c,c++,fortran'
        prefix: {{ aocc_prefix }}
{% endif %}

{% if is_nvhpc and nvhpc_version %}
  # NVHPC — detected from NVHPC_VERSION / NVHPC_ROOT set by module load nvhpc.
  nvhpc:
    buildable: false
    externals:
      - spec: nvhpc@{{ nvhpc_version }} languages='c,c++,fortran,cuda'
        prefix: {{ nvhpc_prefix }}
{% endif %}

{% if is_rocmcc and rocmcc_version %}
  # ROCmCC — detected from ROCM_VERSION / ROCM_PATH set by module load rocm.
  rocmcc:
    buildable: false
    externals:
      - spec: rocmcc@{{ rocmcc_version }} languages='c,c++,fortran'
        prefix: {{ rocmcc_prefix }}
{% endif %}

{% if is_intel and intel_version %}
  # Intel oneAPI — detected from ONEAPI_ROOT set by setvars.sh or module load intel.
  intel-oneapi-compilers:
    buildable: false
    externals:
      - spec: intel-oneapi-compilers@{{ intel_version }}
        prefix: {{ intel_prefix }}
{% endif %}

{% if is_mpich and has_cray_pals %}
  # cray-pals — PBS job launcher / PMIx provider on Cray systems.
  # Provides mpiexec that hooks into Slingshot for PBS compute node launch.
  # Absent on Slurm Cray systems; detected automatically by Stage 1.
  pals:
    buildable: false
    externals:
      - spec: pals@{{ cray_pals_version }}
        prefix: {{ cray_pals_prefix }}
{% if cray_pals_module %}
        modules: [{{ cray_pals_module }}]
{% else %}
        modules: [cray-pals/{{ cray_pals_version }}]
{% endif %}
{% endif %}
