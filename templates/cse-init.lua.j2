-- cse-init/{{ "openmpi" if is_openmpi else "mpich" }}.lua
-- Activation module for the CSE {{ "OpenMPI" if is_openmpi else "MPICH" }} variant.
-- Rendered by Stage 5 with literal install paths.

help([[
The CSE {{ "OpenMPI" if is_openmpi else "MPICH" }} variant ({{ variant }}).
After loading this module, packages are available under the cse/* namespace.
Try:  module avail cse
      module load cse/{{ mpi_provider }} cse/hdf5-mpi cse/netcdf-fortran-mpi
]])

whatis("Name        : cse-init/{{ "openmpi" if is_openmpi else "mpich" }}")
whatis("Description : Activates the CSE {{ "OpenMPI" if is_openmpi else "MPICH" }} variant for release {{ CSE_RELEASE }}")

family("cse_init")

local cse_release = "{{ CSE_RELEASE }}"
local shared_path = "{{ SHARED_PATH }}"
local variant     = "{{ variant }}"
local cse_root    = pathJoin(shared_path, "cse", cse_release, variant)
local mod_root    = "{{ init_module_root }}"
local gcc_root    = "{{ cse_gcc_root }}"

setenv("CSE_RELEASE", cse_release)
setenv("CSE_VARIANT", variant)
setenv("CSE_MPI", "{{ mpi_provider }}")
setenv("CSE_ROOT", cse_root)
setenv("CSE_GCC_ROOT", gcc_root)
setenv("CSE_CC", "{{ cse_cc }}")
setenv("CSE_CXX", "{{ cse_cxx }}")
setenv("CSE_FC", "{{ cse_fc }}")
prepend_path("PATH", pathJoin(gcc_root, "bin"))
prepend_path("MODULEPATH", mod_root)
