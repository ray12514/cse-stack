spack:
  include:
    - ./packages.yaml
    - ./config.yaml
    - ./modules.yaml
{% if gcc_compilers_yaml_exists %}
    # Written by scripts/stage2_spack.sh — compiler entries for the
    # bootstrapped GCC, read by stage 4 concretization and build.
    - ../gcc-compilers.yaml
{% endif %}
{% if gcc_bootstrap_yaml_exists %}
    # Written by scripts/stage2_spack.sh — survives re-renders of the
    # other includes because it lives next to (not inside) the env dir.
    - ../gcc-bootstrap.yaml
{% endif %}

  view:
    cse_modules:
      root: {{ views_root }}/modules
      projections:
        boost+mpi: "{name}/{version}/mpi"
        boost~mpi: "{name}/{version}/serial"
        all: "{name}/{version}"
        "+mpi": "{name}/{version}-mpi"
        "~mpi": "{name}/{version}-serial"
        "^netcdf-c +mpi": "{name}/{version}-mpi"
        "^netcdf-c ~mpi": "{name}/{version}-serial"
      link: all
      link_type: symlink
{% if view_mpi_select %}
    mpi:
      root: {{ views_root }}/mpi
      projections:
        boost+mpi: "{name}/{version}/mpi"
        boost~mpi: "{name}/{version}/serial"
        all: "{name}/{version}"
        "+mpi": "{name}/{version}-mpi"
        "~mpi": "{name}/{version}-serial"
        "^netcdf-c +mpi": "{name}/{version}-mpi"
        "^netcdf-c ~mpi": "{name}/{version}-serial"
      select:
{% for item in view_mpi_select %}
        - "{{ item }}"
{% endfor %}
      link: all
      link_type: symlink
{% endif %}
{% if view_serial_select %}
    serial:
      root: {{ views_root }}/serial
      projections:
        boost+mpi: "{name}/{version}/mpi"
        boost~mpi: "{name}/{version}/serial"
        all: "{name}/{version}"
        "+mpi": "{name}/{version}-mpi"
        "~mpi": "{name}/{version}-serial"
        "^netcdf-c +mpi": "{name}/{version}-mpi"
        "^netcdf-c ~mpi": "{name}/{version}-serial"
      select:
{% for item in view_serial_select %}
        - "{{ item }}"
{% endfor %}
      link: all
      link_type: symlink
{% endif %}

  concretizer:
    unify: when_possible
    reuse:  true

  specs:
{% for entry in spack_spec_entries %}
{{ entry }}
{% endfor %}
