spack:
  include:
    - ./packages.yaml
    - ./config.yaml
    - ./modules.yaml
{% if mirrors_yaml_enabled %}
    # Written by stage 4 when --mirror-path or --buildcache-uri is set.
    - ./mirrors.yaml
{% endif %}
{% if gcc_compilers_yaml_exists %}
    # Written by scripts/stage2_spack.sh — compiler entries for the
    # bootstrapped GCC, read by stage 4 concretization and build.
    - ../gcc-compilers.yaml
{% endif %}
{% if gcc_bootstrap_yaml_exists %}
    # Written by scripts/stage2_spack.sh — survives re-renders of the
    # other includes because it lives next to (not inside) the env dir.
    - ../gcc-bootstrap.yaml
{% endif %}

  view:
    cse_modules:
      root: {{ views_root }}/modules
      projections:
{% for name in clean_view_projection_names %}
        {{ name }}: "{name}/{version}"
{% endfor %}
        boost+mpi: "{name}/{version}/mpi"
        boost~mpi: "{name}/{version}/serial"
        fftw+mpi: "{name}/{version}-mpi"
        fftw~mpi: "{name}/{version}-serial"
        hdf5+mpi: "{name}/{version}-mpi"
        hdf5~mpi: "{name}/{version}-serial"
        netcdf-c+mpi: "{name}/{version}-mpi"
        netcdf-c~mpi: "{name}/{version}-serial"
        "netcdf-fortran ^netcdf-c+mpi": "{name}/{version}-mpi"
        "netcdf-fortran ^netcdf-c~mpi": "{name}/{version}-serial"
        "netcdf-cxx4 ^netcdf-c+mpi": "{name}/{version}-mpi"
        "netcdf-cxx4 ^netcdf-c~mpi": "{name}/{version}-serial"
        all: "{name}/{version}/{hash:7}"
      link: all
      link_type: symlink
{% if view_mpi_select %}
    mpi:
      root: {{ views_root }}/mpi
      projections:
{% for name in clean_view_projection_names %}
        {{ name }}: "{name}/{version}"
{% endfor %}
        boost+mpi: "{name}/{version}/mpi"
        boost~mpi: "{name}/{version}/serial"
        fftw+mpi: "{name}/{version}-mpi"
        fftw~mpi: "{name}/{version}-serial"
        hdf5+mpi: "{name}/{version}-mpi"
        hdf5~mpi: "{name}/{version}-serial"
        netcdf-c+mpi: "{name}/{version}-mpi"
        netcdf-c~mpi: "{name}/{version}-serial"
        "netcdf-fortran ^netcdf-c+mpi": "{name}/{version}-mpi"
        "netcdf-fortran ^netcdf-c~mpi": "{name}/{version}-serial"
        "netcdf-cxx4 ^netcdf-c+mpi": "{name}/{version}-mpi"
        "netcdf-cxx4 ^netcdf-c~mpi": "{name}/{version}-serial"
        all: "{name}/{version}/{hash:7}"
      select:
{% for item in view_mpi_select %}
        - "{{ item }}"
{% endfor %}
      link: all
      link_type: symlink
{% endif %}
{% if view_serial_select %}
    serial:
      root: {{ views_root }}/serial
      projections:
{% for name in clean_view_projection_names %}
        {{ name }}: "{name}/{version}"
{% endfor %}
        boost+mpi: "{name}/{version}/mpi"
        boost~mpi: "{name}/{version}/serial"
        fftw+mpi: "{name}/{version}-mpi"
        fftw~mpi: "{name}/{version}-serial"
        hdf5+mpi: "{name}/{version}-mpi"
        hdf5~mpi: "{name}/{version}-serial"
        netcdf-c+mpi: "{name}/{version}-mpi"
        netcdf-c~mpi: "{name}/{version}-serial"
        "netcdf-fortran ^netcdf-c+mpi": "{name}/{version}-mpi"
        "netcdf-fortran ^netcdf-c~mpi": "{name}/{version}-serial"
        "netcdf-cxx4 ^netcdf-c+mpi": "{name}/{version}-mpi"
        "netcdf-cxx4 ^netcdf-c~mpi": "{name}/{version}-serial"
        all: "{name}/{version}/{hash:7}"
      select:
{% for item in view_serial_select %}
        - "{{ item }}"
{% endfor %}
      link: all
      link_type: symlink
{% endif %}

  concretizer:
    unify: when_possible
    reuse:  true

  specs:
{% for entry in spack_spec_entries %}
{{ entry }}
{% endfor %}
