modules:
  prefix_inspections:
    bin:
      - PATH
    lib:
      - LD_LIBRARY_PATH
    lib64:
      - LD_LIBRARY_PATH
    include:
      - CPATH
    lib/pkgconfig:
      - PKG_CONFIG_PATH
    lib64/pkgconfig:
      - PKG_CONFIG_PATH
    share/man:
      - MANPATH
    share/pkgconfig:
      - PKG_CONFIG_PATH
    .:
      - CMAKE_PREFIX_PATH

  default:
    enable:
      - {{ module_system }}
    use_view: cse_modules
    roots:
      {{ module_system }}: {{ module_root }}
    {{ module_system }}:
{% if module_system == "lmod" %}
      hierarchy: []
{% endif %}
      hash_length: 0
      include:
{% for spec in public_module_include_specs %}
        - '{{ spec }}'
{% endfor %}
      exclude:
        - '*'
      projections:
        all: 'cse/{name}/{version}'
      all:
        autoload: none

      hdf5:
        suffixes:
          '+mpi': 'mpi'
          '~mpi': 'serial'

{% if load_hdf5_mpi %}
      hdf5 +mpi:
        load:
          - '{{ mpi_module }}'
{% endif %}

      netcdf-c:
        suffixes:
          '+mpi': 'mpi'
          '~mpi': 'serial'

{% if load_netcdf_c_mpi %}
      netcdf-c +mpi:
        load:
          - '{{ hdf5_mpi_module }}'
{% endif %}

{% if load_netcdf_c_serial %}
      netcdf-c ~mpi:
        load:
          - '{{ hdf5_serial_module }}'
{% endif %}

      netcdf-fortran:
        suffixes:
          '^netcdf-c +mpi': 'mpi'
          '^netcdf-c ~mpi': 'serial'

{% if load_netcdf_fortran_mpi %}
      netcdf-fortran ^netcdf-c +mpi:
        load:
          - '{{ netcdf_c_mpi_module }}'
{% endif %}

{% if load_netcdf_fortran_serial %}
      netcdf-fortran ^netcdf-c ~mpi:
        load:
          - '{{ netcdf_c_serial_module }}'
{% endif %}

      netcdf-cxx4:
        suffixes:
          '^netcdf-c +mpi': 'mpi'
          '^netcdf-c ~mpi': 'serial'

{% if load_netcdf_cxx4_mpi %}
      netcdf-cxx4 ^netcdf-c +mpi:
        load:
          - '{{ netcdf_c_mpi_module }}'
{% endif %}

{% if load_netcdf_cxx4_serial %}
      netcdf-cxx4 ^netcdf-c ~mpi:
        load:
          - '{{ netcdf_c_serial_module }}'
{% endif %}

{% if is_openmpi %}
      openmpi:
        autoload: none
{% else %}
      mpich:
        autoload: none
{% endif %}
